# Database connection string
DATABASE_URL=postgresql://127.0.0.1:5432/PFE_DATA
SQL_DATABASE_URL=

# Example Mongo connection string if you ever switch back
#DATABASE_URL=mongodb://127.0.0.1/PFE_DATA

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SMTP used by Payload notification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=YOUR_GOOGLE_APP_PASSWORD
SMTP_FROM_ADDRESS=your-email@gmail.com
SMTP_FROM_NAME=Dream PFE
# Set to true only if your local SMTP setup has certificate issues
SMTP_ALLOW_UNAUTHORIZED=false

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Optional AI coaching
GROQ_API_KEY=
GROQ_COACHING_MODEL=llama-3.1-8b-instant

# Optional voice features for coaching STT/TTS
GOOGLE_STT_KEY=
GOOGLE_TTS_KEY=
GOOGLE_TTS_VOICE=fr-FR-Neural2-B
